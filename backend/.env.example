# ========================================
# CONFIGURACIÓN DE ENTORNO - BACKEND
# ========================================

# Entorno (development, production)
NODE_ENV=development

# Puerto del servidor (Railway lo asigna automáticamente en producción)
PORT=3000

# ========================================
# BASE DE DATOS (PostgreSQL)
# ========================================
# Desarrollo local:
# DATABASE_URL="postgresql://usuario:password@localhost:5432/fifpro2k26_dev"

# Producción (Railway):
# Railway genera automáticamente DATABASE_URL cuando conectas PostgreSQL
# No necesitas configurarlo manualmente en Railway
DATABASE_URL="postgresql://usuario:password@host:5432/database"

# ========================================
# JWT (Autenticación)
# ========================================
# Generar secreto seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ========================================
# CORS
# ========================================
# Desarrollo local:
CORS_ORIGIN=http://localhost:5173

# Producción (actualizar con tu dominio de Netlify):
# CORS_ORIGIN=https://tu-app.netlify.app
